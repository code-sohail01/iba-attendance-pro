{
  "manifest_version": 3,
  "name": "IBA Attendance Pro",
  "version": "1.0",
  "description": "The ultimate attendance dashboard for Sukkur IBA students. Instantly track subjects, calculate safe skips and sync your profile.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["*://*.iba-suk.edu.pk/*"],
  "icons": { "128": "icon.png" },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html",
    "default_title": "IBA Controls"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["*://*.iba-suk.edu.pk/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}